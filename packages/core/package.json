{
  "name": "@synapsenodes/core",
  "version": "0.3.0",
  "description": "The AI Runtime Layer for Frontend Applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/client.ts --format cjs,esm --dts --watch",
    "create-feat": "node scripts/create-feat.mjs"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.58",
    "@ai-sdk/cohere": "3.0.25",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/mistral": "3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/perplexity": "3.0.23",
    "ai": "^6.0.116",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  }
}
